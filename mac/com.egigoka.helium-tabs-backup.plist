<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.egigoka.helium-tabs-backup</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-c</string>
		<string>/usr/bin/python3 "$HOME/.scripts/helium-tabs-backup.py"</string>
	</array>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Minute</key>
		<integer>0</integer>
	</dict>
	<key>StandardOutPath</key>
	<string>/tmp/helium-tabs-backup.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/helium-tabs-backup.log</string>
	<key>RunAtLoad</key>
	<false/>
</dict>
</plist>
