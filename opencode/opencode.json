{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-with-claude", "opencode-claude-memory"],
  "provider": {
      "anthropic": {
        "options": {
          "baseURL": "http://127.0.0.1:3456",
          "apiKey": "dummy"
        }
      }
    },
  "permission": {
    "*": "ask",
    "bash": {
      "basename": "allow",
      "date": "allow",
      "dirname": "allow",
      "false": "allow",
      "file": "allow",
      "find": "allow",
      "git status": "allow",
      "rg": "allow",
      "ripgrep": "allow",
      "grep": "allow",
      "id": "allow",
      "printf": "allow",
      "python3 -m py_compile": "allow",
      "pwd": "allow",
      "realpath": "allow",
      "true": "allow",
      "uname": "allow",
      "wc": "allow",
      "whoami": "allow",
      "which": "allow",
      "*": "ask"
    }
  }
}
