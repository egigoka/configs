  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "todowrite": "allow",
    "webfetch": "allow",
    "skill": "allow",
