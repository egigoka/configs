#!/usr/bin/env bash
set -euo pipefail

FILE="codex/codex.toml"

if ! git diff --cached --name-only --diff-filter=ACMR | grep -qx "$FILE"; then
    exit 0
fi

current_blob=$(git ls-files --stage -- "$FILE" | awk '{print $2}')
if [[ -z "$current_blob" ]]; then
    exit 0
fi

cleaned_blob=$(git cat-file -p "$current_blob" | hooks/filter-codex-projects | git hash-object -w --stdin)

if [[ "$current_blob" != "$cleaned_blob" ]]; then
    git update-index --cacheinfo "100644,$cleaned_blob,$FILE"
    echo "pre-commit: stripped [projects.*] and trust_level entries from $FILE"
fi
