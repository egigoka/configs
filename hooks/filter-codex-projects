#!/usr/bin/env python3
import sys

lines = sys.stdin.read().splitlines()
out = []
in_projects = False

for line in lines:
    stripped = line.strip()
    if stripped.startswith("[") and stripped.endswith("]"):
        in_projects = stripped == "[projects]" or stripped.startswith("[projects.")
        if in_projects:
            while out and not out[-1].strip():
                out.pop()
            continue
    if not in_projects:
        out.append(line)

while out and not out[-1].strip():
    out.pop()
sys.stdout.write("\n".join(out) + "\n")
