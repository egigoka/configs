{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-claude-memory",
    "opencode-throughput",
    "opencode-log-sanitizer",
    "@tarquinen/opencode-dcp@latest",
    "@atonev/opencode-short-term-memory@latest",
    "./plugins/caveman/plugin.js",
    "opencode-kilo-auth@latest",
    "@dietrichgeber/ponytail",
    "opencode-openai-multi-auth",
    "opencode-openai-sub-switcher@latest"
  ],
  "provider": {
    "openai": {
      "options": {
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "textVerbosity": "medium",
        "include": [
          "reasoning.encrypted_content"
        ],
        "store": false
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT 5.2 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.2-codex": {
          "name": "GPT 5.2 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            },
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex": {
          "name": "GPT 5.1 Codex (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT 5.1 Codex Mini (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "medium"
            }
          }
        },
        "gpt-5.1": {
          "name": "GPT 5.1 (OAuth)",
          "limit": {
            "context": 272000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "variants": {
            "none": {
              "reasoningEffort": "none",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "low": {
              "reasoningEffort": "low",
              "reasoningSummary": "auto",
              "textVerbosity": "low"
            },
            "medium": {
              "reasoningEffort": "medium",
              "reasoningSummary": "auto",
              "textVerbosity": "medium"
            },
            "high": {
              "reasoningEffort": "high",
              "reasoningSummary": "detailed",
              "textVerbosity": "high"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "cua-driver": {
      "type": "local",
      "command": [
        "cua-driver",
        "mcp"
      ],
      "enabled": true
    },
    "xcode": {
      "type": "local",
      "command": [
        "xcrun",
        "mcpbridge"
      ],
      "enabled": true
    },
    "mobile-mcp": {
      "type": "local",
      "command": [
        "mcp-server-mobile"
      ],
      "environment": {
        "MOBILEMCP_DISABLE_TELEMETRY": "1"
      },
      "enabled": true
    },
    "xcodebuild-mcp": {
      "type": "local",
      "command": [
        "xcodebuildmcp",
        "mcp"
      ],
      "environment": {
        "XCODEBUILDMCP_SENTRY_DISABLED": "true"
      },
      "enabled": true
    }
  },
  "experimental": {
    "mcp_timeout": 120000,
    "openTelemetry": true
  },
  "permission": {
    "*": "ask",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*secrets.py": "deny",
      "*secret*": "deny",
      "*token*": "deny",
      "*.key": "deny",
      "*.pem": "deny"
    },
    "glob": "allow",
    "grep": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "bash": {
      "*": "ask",
      "basename": "allow",
      "date": "allow",
      "dirname": "allow",
      "false": "allow",
      "file": "allow",
      "find": "allow",
      "graphify *": "allow",
      "git status": "allow",
      "rg": "allow",
      "ripgrep": "allow",
      "grep": "allow",
      "id": "allow",
      "ls": "allow",
      "ls *": "allow",
      "printf": "allow",
      "python3 -m py_compile": "allow",
      "pwd": "allow",
      "realpath": "allow",
      "rocketsim *": "allow",
      "true": "allow",
      "uname": "allow",
      "wc": "allow",
      "whoami": "allow",
      "which": "allow",
      "kilo *": "allow",
      "opencode *": "allow",
      "which *": "allow",
      "gh search code *": "allow",
      "gh search issues *": "allow",
      "gh pr view *": "allow",
      "npm root *": "allow",
      "gh api 'repos/Kilo-Org/kilocode/git/trees/main?recursive=1' *": "allow",
      "git status *": "allow",
      "npm view @kilocode/cli *": "allow",
      "python3 *": "allow",
      "git --no-pager *": "allow",
      "git log *": "allow",
      "bash *": "allow",
      "jq *": "allow",
      "git add *": "allow",
      "git diff *": "allow",
      "git commit *": "allow",
      "git push *": "allow"
    },
    "external_directory": {
      "/Users/egigoka/.config/opencode/*": "allow",
      "/Users/egigoka/.config/kilo/*": "allow",
      "/Users/egigoka/.local/share/*": "allow",
      "/Users/egigoka/.npm-global/lib/node_modules/*": "allow"
    },
    "cua-driver_start_session": {
      "*": "allow"
    },
    "cua-driver_launch_app": {
      "*": "allow"
    },
    "cua-driver_list_windows": {
      "*": "allow"
    },
    "cua-driver_page": {
      "*": "allow"
    },
    "cua-driver_end_session": {
      "*": "allow"
    },
    "compress": {
      "*": "allow"
    },
    "task": {
      "*": "allow"
    }
  }
}